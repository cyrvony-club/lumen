{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:product-knowledge-package:schema:product-truth-model",
  "title": "ProductTruthModel",
  "type": "object",
  "required": [
    "schema_version",
    "product_id",
    "updated_at",
    "brief",
    "claims",
    "evidence",
    "target_llm_queries",
    "source_of_truth",
    "policy_constraints"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Версия схемы product-truth-model"
    },
    "product_id": {
      "type": "string",
      "description": "Стабильный идентификатор продукта в пакете"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "brief": {
      "type": "object",
      "required": ["name", "category", "website", "short_description"],
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "website": { "type": "string", "format": "uri" },
        "short_description": { "type": "string" },
        "audiences": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "positioning": {
      "type": "object",
      "properties": {
        "fit_for": { "type": "array", "items": { "type": "string" } },
        "not_fit_for": { "type": "array", "items": { "type": "string" } },
        "use_cases": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "statement", "truth_status"],
        "properties": {
          "id": { "type": "string" },
          "statement": { "type": "string" },
          "kind": {
            "type": "string",
            "description": "Например: capability, limit, metric, positioning"
          },
          "truth_status": {
            "type": "string",
            "enum": ["evidenced", "hypothesis", "policy_forbidden"]
          },
          "evidence_ids": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "entity_id": {
            "type": "string",
            "description": "Связанная сущность Claim в entities.jsonl, если есть"
          }
        },
        "additionalProperties": true,
        "allOf": [
          {
            "if": {
              "properties": { "truth_status": { "const": "evidenced" } },
              "required": ["truth_status"]
            },
            "then": {
              "required": ["evidence_ids"],
              "properties": {
                "evidence_ids": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "type": "string", "minLength": 1 }
                }
              }
            }
          }
        ]
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "kind", "citation"],
        "properties": {
          "id": { "type": "string" },
          "kind": {
            "type": "string",
            "description": "Например: url, quote, screenshot_ref, benchmark, internal_note"
          },
          "citation": { "type": "string", "minLength": 1 },
          "url": { "type": "string", "format": "uri" },
          "entity_id": { "type": "string" },
          "source_refs": {
            "type": "array",
            "description": "Та же форма, что у Entity.chunk source_refs (immutable raw / канонический первоисточник)",
            "items": {
              "type": "object",
              "properties": {
                "ref": {
                  "type": "string",
                  "description": "Стабильный ключ сыроцы (путь репозитория, ключ CMS, immutable ID)"
                },
                "uri": {
                  "type": "string",
                  "format": "uri",
                  "description": "Если сырец уже как URL-снимок"
                },
                "label": { "type": "string" },
                "retrieved_at": { "type": "string", "format": "date-time" },
                "note": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": true
      }
    },
    "competitor_context": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "notes": { "type": "string" },
          "comparison_entity_id": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "target_llm_queries": {
      "type": "array",
      "minItems": 5,
      "maxItems": 8,
      "items": {
        "type": "object",
        "required": ["query"],
        "properties": {
          "query": { "type": "string", "minLength": 1 },
          "coverage_doc_slugs": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": true
      }
    },
    "source_of_truth": {
      "type": "object",
      "properties": {
        "primary_owner": { "type": "string" },
        "documents": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "uri": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "policy_constraints": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
